{
  "name": "@milpa/design",
  "version": "0.1.0",
  "description": "Milpa Design System — dark-first design tokens, motion, and component contracts. The visual face of the Milpa framework.",
  "license": "Apache-2.0",
  "type": "module",
  "private": false,
  "publishConfig": { "access": "public" },
  "files": ["dist", "tokens", "motion", "primitives", "components", "logo", "DESIGN.md"],
  "exports": {
    ".": "./dist/milpa-tokens.css",
    "./css": "./dist/milpa-tokens.css",
    "./tokens": "./tokens/milpa-tokens.json",
    "./tailwind": "./dist/tailwind.config.js",
    "./motion.css": "./motion/milpa-motion.css",
    "./motion": "./motion/milpa-motion.js",
    "./primitives.css": "./primitives/milpa-primitives.css",
    "./components.css": "./components/milpa-components.css",
    "./primitives/*": "./primitives/*",
    "./components/*": "./components/*",
    "./logo/*": "./logo/*"
  },
  "scripts": {
    "build": "node scripts/build-tokens.mjs",
    "test": "node scripts/verify-contrast.mjs && node scripts/verify-governance.mjs && node scripts/build-tokens.mjs --check",
    "proof": "python3 -m http.server 4321"
  },
  "keywords": ["milpa", "design-system", "design-tokens", "dtcg", "dark-mode", "oklch", "tailwind", "motion"],
  "homepage": "https://milpa.lat",
  "repository": { "type": "git", "url": "git+https://github.com/getmilpa/milpa-design.git" },
  "bugs": { "url": "https://github.com/getmilpa/milpa-design/issues" }
}
